{
  "name": "@propulse/api",
  "version": "0.0.0",
  "private": true,
  "description": "Propulse AI backend — NestJS modular monolith. One module per bounded context with hard boundaries (ARCHITECTURE / CLEAN_ARCHITECTURE).",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "boundaries": "depcruise src --config ../../.dependency-cruiser.cjs",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@propulse/config": "workspace:*",
    "@propulse/contracts": "workspace:*",
    "@propulse/database": "workspace:*",
    "@propulse/domain-kernel": "workspace:*",
    "@propulse/observability": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-socket.io": "^10.4.4",
    "@nestjs/websockets": "^10.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@propulse/eslint-config": "workspace:*",
    "@propulse/tsconfig": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "dependency-cruiser": "^16.4.1",
    "eslint": "^9.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
