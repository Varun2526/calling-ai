# Propulse AI — Environment Variables (documentation of truth)
# Copy to .env for local dev. NEVER commit real secrets. In staging/prod these come from
# AWS Secrets Manager / SSM, not files. All env access goes through packages/config (validated).

# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
DATABASE_URL=postgresql://propulse:propulse@localhost:5432/propulse?schema=public
# Connection pool (PgBouncer in prod)
DATABASE_POOL_MAX=10

# ─── Redis / ElastiCache (cache, pub/sub, BullMQ) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / Sessions ──────────────────────────────────────────────────────────
SESSION_SECRET=change-me-locally
JWT_SECRET=change-me-locally
INVITATION_TOKEN_TTL_HOURS=72

# ─── AWS / Storage ──────────────────────────────────────────────────────────-
AWS_REGION=ap-south-1
S3_BUCKET=propulse-local
# Local dev points at LocalStack:
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─── LLM / AI providers ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=
EMBEDDING_MODEL=text-embedding-3-large

# ─── Voice / Telephony ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─── Messaging ────────────────────────────────────────────────────────────────
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=            # for X-Hub-Signature-256 verification

# ─── Maps ─────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Email (SES; Mailhog locally) ────────────────────────────────────────────-
EMAIL_FROM=no-reply@propulse.local
SMTP_URL=smtp://localhost:1025

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
CLOUDWATCH_LOG_GROUP=

# ─── App URLs / Ports ─────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=4000
VOICE_GATEWAY_PORT=4100
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
